// Rtgs_global clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace rtgs_global {

    entity Customer {
        id: string @unique
        email: string
        name: string
        phone: string
        balance: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity PaymentIntent {
        id: string @unique
        customerId: string
        amount: integer
        currency: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Charge {
        id: string @unique
        customerId: string
        paymentIntentId: string
        amount: integer
        currency: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Refund {
        id: string @unique
        chargeId: string
        amount: integer
        reason: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Payout {
        id: string @unique
        amount: integer
        currency: string
        arrivalDate: datetime
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity PaymentMethod {
        id: string @unique
        customerId: string
        type: string
        last4: string
        brand: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
